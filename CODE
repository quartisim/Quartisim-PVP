<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quartisim's PVP</title>
<link href="https://fonts.googleapis.com/css2?family=VT323&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0a0f;
  --panel: #111118;
  --border: #2a2a3a;
  --accent: #e8414b;
  --accent2: #ff8c00;
  --blue: #4a9eff;
  --green: #4aff6a;
  --purple: #b44aff;
  --cyan: #00e5ff;
  --text: #e8e0d0;
  --muted: #556;
  --gold: #ffd700;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Rajdhani',sans-serif;min-height:100vh;overflow:hidden;}
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,0.04) 3px,rgba(0,0,0,0.04) 4px);pointer-events:none;z-index:9999;}

/* SCREENS */
.screen{display:none;position:fixed;inset:0;overflow-y:auto;}
.screen.active{display:flex;flex-direction:column;align-items:center;justify-content:center;}

/* ===== MAIN MENU ===== */
#menu-screen{background:radial-gradient(ellipse at 50% 30%,#1a0808 0%,#0a0a0f 70%);}
.menu-bg-particles{position:fixed;inset:0;pointer-events:none;z-index:0;}
.particle-orb{position:absolute;border-radius:50%;animation:floatOrb linear infinite;}
@keyframes floatOrb{0%{transform:translateY(100vh) scale(0);opacity:0;}10%{opacity:1;}90%{opacity:0.5;}100%{transform:translateY(-100px) scale(1.5);opacity:0;}}
.menu-content{position:relative;z-index:1;text-align:center;padding:20px;}
.game-title{font-family:'VT323',monospace;font-size:clamp(3rem,8vw,6rem);color:var(--accent);text-shadow:0 0 30px rgba(232,65,75,0.8),0 0 80px rgba(232,65,75,0.3);letter-spacing:0.05em;line-height:1;}
.game-subtitle{font-size:1rem;letter-spacing:0.5em;color:var(--muted);margin-top:-8px;margin-bottom:40px;text-transform:uppercase;}
.menu-btn{display:block;width:280px;padding:14px 30px;margin:10px auto;background:transparent;border:2px solid var(--accent);color:var(--accent);font-family:'Rajdhani',sans-serif;font-size:1.2rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;cursor:pointer;position:relative;transition:all 0.2s;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);}
.menu-btn::before{content:'';position:absolute;inset:0;background:var(--accent);transform:scaleX(0);transition:transform 0.2s;transform-origin:left;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);}
.menu-btn:hover{color:#000;text-shadow:none;}
.menu-btn:hover::before{transform:scaleX(1);}
.menu-btn span{position:relative;z-index:1;}
.menu-btn.blue{border-color:var(--blue);color:var(--blue);}
.menu-btn.blue::before{background:var(--blue);}
.menu-btn.green{border-color:var(--green);color:var(--green);}
.menu-btn.green::before{background:var(--green);}
.version-tag{font-size:0.75rem;color:var(--muted);margin-top:30px;letter-spacing:0.3em;}

/* ===== KIT BUILDER ===== */
#kit-screen{background:var(--bg);padding:20px;align-items:stretch;justify-content:flex-start;}
.kit-layout{display:grid;grid-template-columns:1fr 1fr;gap:20px;width:100%;max-width:1100px;margin:0 auto;padding:20px;}
.kit-panel{background:var(--panel);border:1px solid var(--border);padding:20px;}
.panel-title{font-family:'VT323',monospace;font-size:1.8rem;color:var(--accent);letter-spacing:0.15em;border-bottom:1px solid var(--border);padding-bottom:10px;margin-bottom:16px;}
.items-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;}
.item-card{background:#0d0d15;border:1px solid var(--border);padding:10px 8px;cursor:pointer;transition:all 0.15s;text-align:center;position:relative;}
.item-card:hover{border-color:var(--accent);background:rgba(232,65,75,0.08);}
.item-card.selected{border-color:var(--green);background:rgba(74,255,106,0.08);}
.item-card.in-kit{border-color:var(--accent2);}
.item-icon{font-size:1.8rem;display:block;margin-bottom:4px;}
.item-name{font-size:0.65rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--text);}
.item-stat{font-size:0.6rem;color:var(--muted);}
.item-rarity{position:absolute;top:3px;right:4px;font-size:0.5rem;font-weight:700;letter-spacing:0.1em;}
.rarity-s{color:var(--cyan);}
.rarity-a{color:var(--purple);}
.rarity-b{color:var(--accent2);}
.rarity-c{color:#aaa;}

.kit-slots{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:16px;}
.kit-slot{background:#0a0a12;border:2px dashed #333;height:80px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:all 0.15s;position:relative;}
.kit-slot.filled{border-style:solid;border-color:var(--accent2);}
.kit-slot .slot-icon{font-size:1.6rem;}
.kit-slot .slot-name{font-size:0.5rem;color:var(--muted);text-align:center;margin-top:2px;}
.kit-slot .remove-x{position:absolute;top:2px;right:4px;font-size:0.6rem;color:var(--accent);opacity:0;transition:opacity 0.15s;}
.kit-slot:hover .remove-x{opacity:1;}

.settings-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid #1a1a25;}
.settings-label{font-weight:700;font-size:0.9rem;letter-spacing:0.1em;text-transform:uppercase;}
.settings-val{font-size:0.85rem;color:var(--muted);}
.seg-ctrl{display:flex;gap:4px;}
.seg-btn{padding:6px 14px;background:transparent;border:1px solid #333;color:#666;font-family:'Rajdhani',sans-serif;font-size:0.8rem;font-weight:700;cursor:pointer;transition:all 0.15s;text-transform:uppercase;letter-spacing:0.1em;}
.seg-btn.active{background:var(--accent);border-color:var(--accent);color:#000;}
.seg-btn.blue.active{background:var(--blue);border-color:var(--blue);}
.seg-btn.green.active{background:var(--green);border-color:var(--green);}

/* ===== ARENA / GAME SCREEN ===== */
#game-screen{background:var(--bg);padding:0;}
#gameCanvas{display:block;cursor:crosshair;}
#game-hud{position:fixed;inset:0;pointer-events:none;z-index:100;}

/* Health bars */
.hud-health-area{position:absolute;bottom:80px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:4px;}
.health-bar-wrap{width:300px;}
.hbar-label{font-size:0.65rem;letter-spacing:0.2em;color:var(--muted);text-transform:uppercase;margin-bottom:3px;display:flex;justify-content:space-between;}
.hbar{height:14px;background:#111;border:1px solid #333;border-radius:2px;overflow:hidden;position:relative;}
.hbar-fill{height:100%;transition:width 0.2s;border-radius:1px;}
.hbar-fill.player{background:linear-gradient(90deg,#e84040,#ff6060);}
.hbar-fill.enemy{background:linear-gradient(90deg,#40e860,#60ff80);}
.hbar-fill.shield{background:linear-gradient(90deg,var(--blue),var(--cyan));}

/* Hotbar */
.hotbar{position:absolute;bottom:16px;left:50%;transform:translateX(-50%);display:flex;gap:4px;background:rgba(0,0,0,0.7);border:1px solid #333;padding:5px;border-radius:4px;}
.hslot{width:56px;height:56px;background:#0a0a12;border:2px solid #333;display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;transition:border-color 0.1s;}
.hslot.active{border-color:var(--accent);}
.hslot .hicon{font-size:1.5rem;}
.hslot .hname{font-size:0.42rem;color:#aaa;text-align:center;letter-spacing:0.05em;text-transform:uppercase;margin-top:1px;}
.hslot .hkey{position:absolute;top:2px;left:4px;font-size:0.5rem;color:#555;}
.hslot .hcooldown{position:absolute;inset:0;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;color:#fff;border-radius:2px;}

/* Combo/kill feed */
.killfeed{position:absolute;top:16px;right:16px;display:flex;flex-direction:column;gap:4px;align-items:flex-end;}
.kf-entry{background:rgba(0,0,0,0.7);border-left:3px solid var(--accent);padding:4px 10px;font-size:0.75rem;animation:kfSlide 0.3s ease,kfFade 0.5s ease 2.5s forwards;}
@keyframes kfSlide{from{transform:translateX(60px);opacity:0;}to{transform:translateX(0);opacity:1;}}
@keyframes kfFade{to{opacity:0;}}
.combo-display{position:absolute;top:80px;left:50%;transform:translateX(-50%);text-align:center;pointer-events:none;}
.combo-num{font-family:'VT323',monospace;font-size:3rem;color:var(--accent2);text-shadow:0 0 20px rgba(255,140,0,0.8);animation:comboPop 0.2s ease;}
@keyframes comboPop{from{transform:scale(1.5);}to{transform:scale(1);}}
.combo-label{font-size:0.7rem;letter-spacing:0.4em;color:var(--accent2);text-transform:uppercase;}

/* Damage numbers */
.dmg-num{position:absolute;font-family:'VT323',monospace;font-size:1.4rem;font-weight:700;pointer-events:none;animation:dmgFloat 1s ease-out forwards;z-index:200;}
@keyframes dmgFloat{0%{transform:translateY(0) scale(1);opacity:1;}100%{transform:translateY(-60px) scale(0.7);opacity:0;}}

/* Mode indicator */
.mode-badge{position:absolute;top:16px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.8);border:1px solid var(--accent);padding:4px 20px;font-size:0.75rem;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:var(--accent);}

/* Status effects */
.status-effects{position:absolute;top:16px;left:16px;display:flex;gap:6px;}
.se-badge{padding:3px 8px;border-radius:2px;font-size:0.65rem;font-weight:700;letter-spacing:0.1em;border:1px solid;}

/* Crystals on field */
.crystal-indicator{position:absolute;pointer-events:none;text-align:center;}

/* ===== RESULTS ===== */
#result-screen{background:radial-gradient(ellipse at 50% 0%,#1a0808,#0a0a0f 60%);}
.result-content{text-align:center;padding:40px;}
.result-title{font-family:'VT323',monospace;font-size:5rem;margin-bottom:10px;}
.result-title.win{color:var(--gold);text-shadow:0 0 40px rgba(255,215,0,0.6);}
.result-title.loss{color:var(--accent);text-shadow:0 0 40px rgba(232,65,75,0.6);}
.result-stats{background:var(--panel);border:1px solid var(--border);padding:24px 40px;margin:24px auto;max-width:500px;display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.stat-item{text-align:center;}
.stat-val{font-family:'VT323',monospace;font-size:2.5rem;color:var(--accent2);}
.stat-label{font-size:0.7rem;letter-spacing:0.3em;color:var(--muted);text-transform:uppercase;}

/* UTIL */
.back-btn{background:transparent;border:1px solid #333;color:#666;font-family:'Rajdhani',sans-serif;font-size:0.85rem;font-weight:700;padding:8px 20px;cursor:pointer;letter-spacing:0.2em;text-transform:uppercase;transition:all 0.15s;margin-top:10px;}
.back-btn:hover{border-color:var(--accent);color:var(--accent);}
.start-fight-btn{display:block;width:100%;padding:16px;margin-top:20px;background:var(--accent);border:none;color:#000;font-family:'Rajdhani',sans-serif;font-size:1.3rem;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;cursor:pointer;transition:all 0.2s;clip-path:polygon(10px 0%,100% 0%,calc(100% - 10px) 100%,0% 100%);}
.start-fight-btn:hover{background:#ff2030;transform:scale(1.02);}
.kit-name-input{background:#0a0a12;border:1px solid var(--border);color:var(--text);font-family:'Rajdhani',sans-serif;font-size:1rem;padding:8px 12px;width:100%;margin-bottom:12px;outline:none;}
.kit-name-input:focus{border-color:var(--accent);}

/* TOOLTIP */
.tooltip{position:fixed;background:#0d0d18;border:1px solid var(--accent);padding:8px 12px;font-size:0.75rem;pointer-events:none;z-index:9000;max-width:200px;display:none;}
.tooltip.show{display:block;}
.tt-name{font-weight:700;color:var(--text);margin-bottom:4px;font-size:0.85rem;}
.tt-stats{color:var(--muted);}
.tt-rarity{font-size:0.6rem;font-weight:700;letter-spacing:0.2em;}

/* Animations */
@keyframes shakeX{0%,100%{transform:translateX(0);}25%{transform:translateX(-8px);}75%{transform:translateX(8px);}}
.shake{animation:shakeX 0.3s ease;}

/* Crosshair */
#crosshair{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:20px;height:20px;pointer-events:none;}
#crosshair::before,#crosshair::after{content:'';position:absolute;background:rgba(255,255,255,0.8);}
#crosshair::before{width:2px;height:100%;left:50%;transform:translateX(-50%);}
#crosshair::after{height:2px;width:100%;top:50%;transform:translateY(-50%);}

/* Ping / latency fake */
.ping-badge{position:absolute;bottom:80px;right:16px;font-size:0.65rem;color:#4aff6a;font-family:'VT323',monospace;}
</style>
</head>
<body>

<!-- TOOLTIP -->
<div class="tooltip" id="tooltip">
  <div class="tt-rarity" id="tt-rarity"></div>
  <div class="tt-name" id="tt-name"></div>
  <div class="tt-stats" id="tt-stats"></div>
</div>

<!-- ===== MAIN MENU ===== -->
<div class="screen active" id="menu-screen">
  <div class="menu-bg-particles" id="bg-particles"></div>
  <div class="menu-content">
    <div class="game-title">QUARTISIM'S</div>
    <div class="game-title" style="font-size:clamp(2rem,6vw,4.5rem);color:#fff;text-shadow:0 0 20px rgba(255,255,255,0.3);">PVP</div>
    <div class="game-subtitle">No rules. Just combat.</div>
    <button class="menu-btn" onclick="showScreen('kit-screen')"><span>⚔ Build Kit & Fight</span></button>
    <button class="menu-btn blue" onclick="quickFight()"><span>⚡ Quick Fight</span></button>
    <div class="version-tag">v1.0 — 1.8 · Crystal · Mace · 1.21 PVP</div>
  </div>
</div>

<!-- ===== KIT BUILDER ===== -->
<div class="screen" id="kit-screen" style="justify-content:flex-start;padding-top:20px;">
  <div style="width:100%;max-width:1100px;margin:0 auto;padding:0 20px;">
    <div style="display:flex;align-items:center;gap:16px;margin-bottom:16px;">
      <button class="back-btn" onclick="showScreen('menu-screen')">← Back</button>
      <h2 style="font-family:'VT323',monospace;font-size:2rem;color:var(--accent);letter-spacing:0.1em;">KIT BUILDER</h2>
    </div>
  </div>
  <div class="kit-layout">
    <!-- LEFT: items -->
    <div>
      <div class="kit-panel">
        <div class="panel-title">🗡 Available Items</div>
        <div class="items-grid" id="items-grid"></div>
      </div>
    </div>
    <!-- RIGHT: kit + settings -->
    <div style="display:flex;flex-direction:column;gap:16px;">
      <div class="kit-panel">
        <div class="panel-title">🎒 Your Kit <span style="font-size:0.9rem;color:var(--muted);">(max 9 slots)</span></div>
        <input class="kit-name-input" id="kit-name" placeholder="Kit name (e.g. Crystal God)" maxlength="24">
        <div class="kit-slots" id="kit-slots"></div>
        <div id="kit-warning" style="font-size:0.75rem;color:var(--accent);min-height:18px;"></div>
      </div>
      <div class="kit-panel">
        <div class="panel-title">⚙ Match Settings</div>
        <div class="settings-row">
          <div class="settings-label">PVP Mode</div>
          <div class="seg-ctrl" id="pvp-mode-ctrl">
            <button class="seg-btn active" data-mode="1.8" onclick="setMode('pvp-mode-ctrl',this,'1.8')">1.8</button>
            <button class="seg-btn" data-mode="crystal" onclick="setMode('pvp-mode-ctrl',this,'crystal')">Crystal</button>
            <button class="seg-btn" data-mode="mace" onclick="setMode('pvp-mode-ctrl',this,'mace')">Mace</button>
            <button class="seg-btn" data-mode="1.21" onclick="setMode('pvp-mode-ctrl',this,'1.21')">1.21</button>
          </div>
        </div>
        <div class="settings-row">
          <div class="settings-label">Bot Difficulty</div>
          <div class="seg-ctrl" id="diff-ctrl">
            <button class="seg-btn green active" data-val="easy" onclick="setMode('diff-ctrl',this,'easy')">Easy</button>
            <button class="seg-btn blue" data-val="medium" onclick="setMode('diff-ctrl',this,'medium')">Medium</button>
            <button class="seg-btn" data-val="hard" onclick="setMode('diff-ctrl',this,'hard')">Hard</button>
            <button class="seg-btn" data-val="insane" onclick="setMode('diff-ctrl',this,'insane')" style="border-color:var(--purple);color:var(--purple);">Insane</button>
          </div>
        </div>
        <div class="settings-row">
          <div class="settings-label">Bot Count</div>
          <div class="seg-ctrl" id="bots-ctrl">
            <button class="seg-btn active" data-val="1" onclick="setMode('bots-ctrl',this,'1')">1v1</button>
            <button class="seg-btn" data-val="2" onclick="setMode('bots-ctrl',this,'2')">1v2</button>
            <button class="seg-btn" data-val="3" onclick="setMode('bots-ctrl',this,'3')">1v3</button>
          </div>
        </div>
        <div class="settings-row">
          <div class="settings-label">Arena</div>
          <div class="seg-ctrl" id="arena-ctrl">
            <button class="seg-btn active" data-val="flat" onclick="setMode('arena-ctrl',this,'flat')">Flat</button>
            <button class="seg-btn" data-val="pillars" onclick="setMode('arena-ctrl',this,'pillars')">Pillars</button>
            <button class="seg-btn" data-val="sky" onclick="setMode('arena-ctrl',this,'sky')">Sky</button>
          </div>
        </div>
        <button class="start-fight-btn" onclick="startFight()">START FIGHT →</button>
      </div>
    </div>
  </div>
</div>

<!-- ===== GAME SCREEN ===== -->
<div class="screen" id="game-screen">
  <canvas id="gameCanvas"></canvas>
  <div id="game-hud">
    <div id="crosshair"></div>
    <div class="mode-badge" id="mode-badge">1.8 PVP</div>
    <div class="killfeed" id="killfeed"></div>
    <div class="combo-display" id="combo-display" style="display:none;"></div>
    <div class="hud-health-area">
      <div class="health-bar-wrap">
        <div class="hbar-label"><span>YOU</span><span id="p-hp-text">20/20</span></div>
        <div class="hbar"><div class="hbar-fill player" id="p-hp-bar" style="width:100%"></div></div>
      </div>
      <div class="health-bar-wrap" id="shield-bar-wrap" style="display:none;">
        <div class="hbar-label"><span>🛡 SHIELD</span><span id="p-shield-text">0</span></div>
        <div class="hbar"><div class="hbar-fill shield" id="p-shield-bar" style="width:0%"></div></div>
      </div>
    </div>
    <div class="hotbar" id="hotbar"></div>
    <div class="status-effects" id="status-effects"></div>
    <div class="ping-badge" id="ping-badge">⬤ 4ms</div>
    <button style="position:absolute;top:16px;left:16px;pointer-events:all;" class="back-btn" onclick="endGame()">✕ Quit</button>
  </div>
</div>

<!-- ===== RESULT SCREEN ===== -->
<div class="screen" id="result-screen">
  <div class="result-content">
    <div class="result-title" id="result-title">YOU WIN</div>
    <div style="font-size:0.9rem;letter-spacing:0.3em;color:var(--muted);margin-bottom:20px;" id="result-sub"></div>
    <div class="result-stats" id="result-stats"></div>
    <button class="menu-btn" style="margin-top:20px;" onclick="showScreen('kit-screen')"><span>↩ Rematch Settings</span></button>
    <button class="menu-btn blue" style="margin-top:0;" onclick="showScreen('menu-screen')"><span>⌂ Main Menu</span></button>
  </div>
</div>

<script>
