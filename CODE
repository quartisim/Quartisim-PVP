// ---- ARENA GEOMETRY ----
let arenaObstacles = []; // {x,y,w,h,color}
let arenaEdge = 400; // half-size of arena

function buildArena() {
  arenaObstacles = [];
  const type = gameState.arena;
  if (type === 'pillars') {
    const positions = [[-150,-120],[150,-120],[-150,120],[150,120],[0,-200],[0,200],[-250,0],[250,0]];
    positions.forEach(([px,py]) => {
      arenaObstacles.push({x:W/2+px-16,y:H/2+py-40,w:32,h:80,color:'#7a7a7a',top:'#9a9a9a'});
    });
  } else if (type === 'sky') {
    // Floating platforms
    const plats = [[-200,20,120,16],[200,-30,100,16],[0,-100,140,16],[-280,60,80,16],[280,0,80,16],[0,80,200,16]];
    plats.forEach(([px,py,pw,ph]) => {
      arenaObstacles.push({x:W/2+px-pw/2,y:H/2+py,w:pw,h:ph,color:'#5a8a3c',top:'#4a7a2c'});
    });
    arenaEdge = 500;
  }
}

// ---- DRAW ARENA ----
function drawArena() {
  // Sky gradient
  const skyGrad = ctx.createLinearGradient(0,0,0,H);
  if (gameState.arena === 'sky') {
    skyGrad.addColorStop(0,'#1a3a6a');
    skyGrad.addColorStop(1,'#0a1a3a');
  } else {
    skyGrad.addColorStop(0,'#87CEEB');
    skyGrad.addColorStop(1,'#c8e8ff');
  }
  ctx.fillStyle = skyGrad;
  ctx.fillRect(0,0,W,H);

  if (gameState.arena !== 'sky') {
    // Ground
    ctx.fillStyle = '#5a8a3c';
    ctx.fillRect(0, H/2+160, W, H);
    ctx.fillStyle = '#4a7a2c';
    ctx.fillRect(0, H/2+155, W, 10);
    // Grid lines on ground
    ctx.strokeStyle = 'rgba(0,0,0,0.05)';
    ctx.lineWidth = 1;
    for (let x = 0; x < W; x += 32) {
      ctx.beginPath(); ctx.moveTo(x, H/2+160); ctx.lineTo(x, H); ctx.stroke();
    }

    // Arena boundary lines
    ctx.strokeStyle = 'rgba(232,65,75,0.3)';
    ctx.lineWidth = 2;
    ctx.setLineDash([8,8]);
    ctx.strokeRect(W/2-arenaEdge, H/2-280, arenaEdge*2, 440);
    ctx.setLineDash([]);
  }

  // Draw obstacles/platforms
  arenaObstacles.forEach(ob => {
    ctx.fillStyle = ob.color;
    ctx.fillRect(ob.x, ob.y, ob.w, ob.h);
    if (ob.top) {
      ctx.fillStyle = ob.top;
      ctx.fillRect(ob.x, ob.y, ob.w, 6);
    }
    // Shadow
    ctx.fillStyle = 'rgba(0,0,0,0.15)';
    ctx.fillRect(ob.x+4, ob.y+ob.h, ob.w-4, 8);
  });
}

// ---- DRAW ENTITY ----
function drawPlayer(ent, isPlayer=false) {
  const {x, y} = ent;
  const alpha = (ent.statusEffects.invis && !isPlayer) ? 0.15 : 1;
  ctx.globalAlpha = alpha;

  // Shadow
  ctx.fillStyle = 'rgba(0,0,0,0.25)';
  ctx.beginPath();
  ctx.ellipse(x, y+2, 14, 5, 0, 0, Math.PI*2);
  ctx.fill();

  // Body
  const bodyColor = isPlayer ? '#3a6aaa' : ent.color;
  ctx.fillStyle = ent.invincibleTimer > 0 ? 'rgba(255,100,100,0.8)' : bodyColor;
  ctx.fillRect(x-10, y-28, 20, 26);

  // Head
  ctx.fillStyle = isPlayer ? '#f5c080' : '#f5c080';
  ctx.fillRect(x-9, y-46, 18, 18);

  // Eyes
  ctx.fillStyle = '#222';
  const eyeDir = ent.facingRight ? 1 : -1;
  ctx.fillRect(x+(eyeDir*2)-1, y-41, 3, 3);

  // Armor tint
  if (isPlayer) {
    ctx.fillStyle = 'rgba(100,150,255,0.35)';
    ctx.fillRect(x-10, y-28, 20, 26);
  } else {
    ctx.fillStyle = 'rgba(200,80,80,0.3)';
    ctx.fillRect(x-10, y-28, 20, 26);
  }

  // Weapon/item swing
  const curItem = ent.items[ent.hotbar];
  if (curItem && ent.attackSwing > 0) {
    const swingAngle = ent.facingRight ? -ent.attackSwing : Math.PI + ent.attackSwing;
    ctx.save();
    ctx.translate(x + (ent.facingRight ? 10 : -10), y-18);
    ctx.rotate(swingAngle);
    ctx.font = '18px serif';
    ctx.fillStyle = '#fff';
    ctx.fillText(curItem.icon, -6, 6);
    ctx.restore();
  } else if (curItem) {
    ctx.font = '16px serif';
    ctx.fillText(curItem.icon, x + (ent.facingRight ? 12 : -26), y-16);
  }

  // Shield block visual
  if (ent.blocking) {
    ctx.fillStyle = 'rgba(74,158,255,0.6)';
    const sx = ent.facingRight ? x+12 : x-22;
    ctx.fillRect(sx, y-35, 10, 28);
  }

  // Name tag
  if (!isPlayer) {
    ctx.globalAlpha = 1;
    ctx.fillStyle = 'rgba(0,0,0,0.6)';
    const nw = ent.name.length * 5.5 + 8;
    ctx.fillRect(x - nw/2, y-62, nw, 14);
    ctx.fillStyle = '#fff';
    ctx.font = '10px "Rajdhani",sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(ent.name, x, y-51);
    ctx.textAlign = 'left';

    // Bot health bar
    const bw = 44;
    ctx.fillStyle = '#111';
    ctx.fillRect(x-bw/2, y-50, bw, 5);
    ctx.fillStyle = ent.hp/ent.maxHp > 0.5 ? '#4aff6a' : ent.hp/ent.maxHp > 0.25 ? '#ff9900' : '#ff4040';
    ctx.fillRect(x-bw/2, y-50, bw*(ent.hp/ent.maxHp), 5);
  }

  // Status indicators
  if (ent.statusEffects.str) { ctx.font='10px serif'; ctx.fillText('⚡',x-6,y-54); }
  if (ent.statusEffects.fire) { ctx.font='12px serif'; ctx.fillText('🔥',x-6,y-62); }

  ctx.globalAlpha = 1;
}

// ---- DRAW PROJECTILES ----
function drawProjectiles() {
  projectiles.forEach(p => {
    ctx.save();
    ctx.translate(p.x, p.y);
    if (p.type === 'arrow') {
      ctx.rotate(Math.atan2(p.vy, p.vx));
      ctx.fillStyle = '#8B6914';
      ctx.fillRect(-8, -1.5, 16, 3);
      ctx.fillStyle = '#555';
      ctx.fillRect(6, -1.5, 4, 3);
    } else if (p.type === 'fireball') {
      ctx.font = '18px serif';
      ctx.fillText('🔥', -9, 7);
    } else if (p.type === 'trident') {
      ctx.rotate(Math.atan2(p.vy, p.vx));
      ctx.font = '18px serif';
      ctx.fillText('🔱', -9, 7);
    } else if (p.type === 'fishHook') {
      ctx.fillStyle = '#ccc';
      ctx.beginPath();
      ctx.arc(0,0,3,0,Math.PI*2);
      ctx.fill();
      // Line back to thrower
      if (p.owner) {
        ctx.strokeStyle = 'rgba(200,200,200,0.4)';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(0,0);
        ctx.lineTo(p.owner.x - p.x, p.owner.y - p.y);
        ctx.stroke();
      }
    } else if (p.type === 'pearl') {
      ctx.fillStyle = '#4aff6a';
      ctx.beginPath();
      ctx.arc(0,0,5,0,Math.PI*2);
      ctx.fill();
    }
    ctx.restore();
  });
}

// ---- DRAW CRYSTALS ----
function drawCrystals() {
  crystals.forEach(c => {
    const pulse = Math.sin(frameCount * 0.08 + c.phase) * 4;
    ctx.save();
    ctx.translate(c.x, c.y + pulse);
    ctx.rotate(frameCount * 0.03 + c.phase);
    // Crystal shape
    const grad = ctx.createRadialGradient(0,0,2,0,0,14);
    grad.addColorStop(0,'rgba(180,74,255,0.9)');
    grad.addColorStop(0.5,'rgba(100,200,255,0.6)');
    grad.addColorStop(1,'rgba(100,200,255,0)');
    ctx.fillStyle = grad;
    ctx.beginPath();
    for (let i = 0; i < 8; i++) {
      const a = (i/8)*Math.PI*2;
      const r = i%2===0 ? 14 : 6;
      i===0 ? ctx.moveTo(Math.cos(a)*r, Math.sin(a)*r) : ctx.lineTo(Math.cos(a)*r, Math.sin(a)*r);
    }
    ctx.closePath();
    ctx.fill();
    // Glow
    ctx.shadowColor = '#b44aff';
    ctx.shadowBlur = 20;
    ctx.fill();
    ctx.restore();

    // HP bar above crystal
    ctx.fillStyle = '#111';
    ctx.fillRect(c.x-18, c.y-36, 36, 5);
    ctx.fillStyle = '#b44aff';
    ctx.fillRect(c.x-18, c.y-36, 36*(c.hp/c.maxHp), 5);
  });
}

// ---- DRAW PARTICLES ----
function drawParticles() {
  particles = particles.filter(p => p.life > 0);
  particles.forEach(p => {
    p.x += p.vx;
    p.y += p.vy;
    p.vy += 0.1;
    p.life--;
    ctx.globalAlpha = p.life / p.maxLife;
    ctx.fillStyle = p.color;
    ctx.beginPath();
    ctx.arc(p.x, p.y, p.size, 0, Math.PI*2);
    ctx.fill();
  });
  ctx.globalAlpha = 1;
}

function spawnParticles(x, y, color, count=8, speed=3) {
  for (let i = 0; i < count; i++) {
    const a = Math.random()*Math.PI*2;
    const s = (0.5+Math.random()*0.5)*speed;
    particles.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s-1,life:20+Math.random()*15,maxLife:35,color,size:2+Math.random()*3});
  }
}

function spawnDmgNum(x, y, dmg, color='#ff4040') {
  const el = document.createElement('div');
  el.className = 'dmg-num';
  el.style.color = color;
  el.style.left = (x + (Math.random()-0.5)*30) + 'px';
  el.style.top = (y - 40) + 'px';
  el.textContent = dmg > 0 ? `-${dmg.toFixed(1)}` : (dmg===0?'BLOCKED':'MISS');
  document.getElementById('game-hud').appendChild(el);
  setTimeout(() => el.remove(), 1000);
}

// ---- LAVA ZONES ----
function drawLava() {
  lavaZones = lavaZones.filter(l => l.life > 0);
  lavaZones.forEach(l => {
    l.life--;
    ctx.fillStyle = `rgba(255,80,0,${0.6*(l.life/l.maxLife)})`;
    ctx.beginPath();
    ctx.ellipse(l.x, l.y, 30, 18, 0, 0, Math.PI*2);
    ctx.fill();
    // Damage entities in range
    if (frameCount % 30 === 0) {
      const all = [player, ...bots];
      all.forEach(e => {
        const d = dist(e.x, e.y, l.x, l.y);
        if (d < 35) {
          applyDamage(e, 2, null, 'fire');
        }
      });
    }
  });
}

// ---- GAME TICK ----
function gameTick() {
  if (!gameActive) return;
  frameCount++;
  ctx.clearRect(0,0,W,H);

  drawArena();
  drawLava();
  drawCrystals();
  drawProjectiles();
  drawParticles();

  // Move projectiles
  updateProjectiles();
  // Move player
  updatePlayer();
  // Update bots
  bots.forEach(b => updateBot(b));

  // Draw player & bots
  bots.forEach(b => drawPlayer(b, false));
  drawPlayer(player, true);

  // Update HUD
  updateHealthUI();
  updateStatusEffects();
  updateCombo();
  renderHotbar();

  // Cleanup
  if (player.hp <= 0) { handlePlayerDeath(); return; }
  if (bots.every(b => b.hp <= 0)) { handleVictory(); return; }

  gameLoop = requestAnimationFrame(gameTick);
}

// ---- PLAYER UPDATE ----
function updatePlayer() {
  const spd = player.speed * (player.statusEffects.spd ? 1.3 : 1) * (player.blocking ? 0.6 : 1);

  if (keys['KeyA'] || keys['ArrowLeft']) { player.x -= spd; player.facingRight = false; }
  if (keys['KeyD'] || keys['ArrowRight']) { player.x += spd; player.facingRight = true; }
  if (keys['KeyW'] || keys['ArrowUp']) player.y -= spd;
  if (keys['KeyS'] || keys['ArrowDown']) player.y += spd;

  // Boundary
  player.x = Math.max(W/2-arenaEdge+20, Math.min(W/2+arenaEdge-20, player.x));
  player.y = Math.max(H/2-250, Math.min(H/2+140, player.y));

  player.facingRight = mousePos.x > player.x;

  // Update swing
  if (player.attackSwing > 0) player.attackSwing -= 0.15;

  // Cooldowns
  Object.keys(player.cooldowns).forEach(k => { if(player.cooldowns[k] > 0) player.cooldowns[k]--; });

  // Status effect timers
  tickStatusEffects(player);

  // Invincibility
  if (player.invincibleTimer > 0) player.invincibleTimer--;

  // Bow hold
  if (player.isBowCharging) {
    player.bowCharge = Math.min(60, player.bowCharge + 1);
  }

  // Auto-attack if holding mouse
  if (mouseDown && frameCount - lastClickTime > getAttackRate(player)) {
    handleClick();
    lastClickTime = frameCount;
  }
}

// ---- BOT UPDATE (AI) ----
function updateBot(bot) {
  if (bot.hp <= 0) return;
  const ai = bot.ai;
  bot.stateTimer++;

  // Cooldowns
  Object.keys(bot.cooldowns).forEach(k => { if(bot.cooldowns[k]>0) bot.cooldowns[k]--; });
  if (bot.invincibleTimer > 0) bot.invincibleTimer--;
  tickStatusEffects(bot);
  if (bot.attackSwing > 0) bot.attackSwing -= 0.12;

  const dx = player.x - bot.x;
  const dy = player.y - bot.y;
  const d = Math.sqrt(dx*dx+dy*dy);
  bot.facingRight = dx > 0;

  // State machine
  if (bot.hp/bot.maxHp < 0.3 && bot.stateTimer % 60 < 30) {
    bot.state = 'retreat';
  } else if (d > 300 && bot.items.find(i=>i.cat==='ranged') && Math.random()<ai.aggression*0.01) {
    bot.state = 'ranged';
  } else if (bot.items.find(i=>i.id==='crystal') && bot.crystalCount > 0 && Math.random()<0.005) {
    bot.state = 'crystalPvp';
  } else {
    bot.state = d > 80 ? 'chase' : 'strafe';
  }

  const spd = bot.speed;

  if (bot.state === 'chase') {
    bot.x += (dx/d)*spd;
    bot.y += (dy/d)*spd*0.5;
  } else if (bot.state === 'strafe') {
    // Strafe around player
    if (bot.stateTimer % Math.floor(1/ai.strafeFreq) === 0) bot.strafeDir *= -1;
    const perpX = -dy/d, perpY = dx/d;
    bot.x += perpX * spd * bot.strafeDir * 1.2;
    bot.y += perpY * spd * bot.strafeDir * 0.6;
    // Still approach slightly
    bot.x += (dx/d)*spd*0.3;
  } else if (bot.state === 'retreat') {
    bot.x -= (dx/d)*spd*1.2;
    bot.y -= (dy/d)*spd*0.8;
    // Heal if have potion
    const healPot = bot.items.find(i=>i.id==='pot_heal' && i.count>0);
    if (healPot && !bot.cooldowns.heal && bot.hp < bot.maxHp-4) {
      healPot.count--;
      bot.hp = Math.min(bot.maxHp, bot.hp+8);
      bot.cooldowns.heal = 120;
      spawnParticles(bot.x, bot.y, '#ff4aaa', 6);
    }
  } else if (bot.state === 'ranged') {
    // Keep distance, shoot
    if (d < 200) {
      bot.x -= (dx/d)*spd;
    } else {
      bot.x += (dx/d)*spd*0.3;
    }
  } else if (bot.state === 'crystalPvp') {
    // Place crystal near player
    if (!bot.cooldowns.crystal && bot.crystalCount > 0) {
      const cx = player.x + (Math.random()-0.5)*60;
      const cy = player.y - 20;
      placeCrystal(cx, cy, bot);
      bot.crystalCount--;
      bot.cooldowns.crystal = 40;
      // Immediately explode nearest crystal
      setTimeout(() => {
        if (crystals.length > 0) {
          const c = crystals[crystals.length-1];
          explodeCrystal(c);
        }
      }, 300);
    }
  }

  // Attack
  const attackRange = getWeaponRange(bot.items[bot.hotbar]);
  if (d < attackRange && bot.stateTimer % Math.max(4, ai.reactionTime) === 0) {
    botAttack(bot, d);
  }

  // Hotbar switch
  if (bot.stateTimer % 90 === 0) {
    // Switch to best weapon for situation
    const swordIdx = bot.items.findIndex(i=>i.cat==='sword'||i.cat==='axe'||i.cat==='mace');
    const bowIdx = bot.items.findIndex(i=>i.cat==='ranged');
    if (d > 250 && bowIdx !== -1) bot.hotbar = bowIdx;
    else if (swordIdx !== -1) bot.hotbar = swordIdx;
  }

  // Boundary
  bot.x = Math.max(W/2-arenaEdge+20, Math.min(W/2+arenaEdge-20, bot.x));
  bot.y = Math.max(H/2-250, Math.min(H/2+140, bot.y));

  // Shield
  const shieldItem = bot.items.find(i=>i.id==='shield'&&!i.broken);
  if (shieldItem && d > 100 && Math.random() < ai.blockChance * 0.02) {
    bot.blocking = true;
  } else {
    bot.blocking = false;
  }
}

function botAttack(bot, dist) {
  const item = bot.items[bot.hotbar];
  if (!item) return;
  const ai = bot.ai;
  const aimErr = ai.aimErr;

  if (item.cat === 'sword' || item.cat === 'axe' || item.cat === 'mace') {
    if (dist < getWeaponRange(item)) {
      const dmg = calculateDamage(item, bot, null, 0);
      applyDamage(player, dmg, bot, item.cat);
      bot.attackSwing = 1.2;
      spawnParticles(player.x, player.y, '#ff4040', 5);
    }
  } else if (item.cat === 'ranged') {
    const errX = (Math.random()-0.5)*aimErr*2;
    const errY = (Math.random()-0.5)*aimErr;
    fireProjectile(bot, player.x+errX, player.y+errY, item);
  }

  // Potion use
  if (Math.random() < 0.005 && bot.hp < bot.maxHp*0.5) {
    const pot = bot.items.find(i=>i.id==='pot_heal'&&i.count>0);
    if (pot) { pot.count--; bot.hp=Math.min(bot.maxHp,bot.hp+8); }
  }
}

// ---- CLICK HANDLER (PLAYER ATTACK) ----
function handleClick() {
  if (!gameActive) return;
  const item = player.items[player.hotbar];
  if (!item) return;

  if (item.cat === 'ranged' && item.id !== 'crossbow') {
    player.isBowCharging = true;
    return;
  }

  if (item.id === 'crystal') {
    if (item.count <= 0) { killFeed('No crystals left!', '#888'); return; }
    placeCrystal(mousePos.x, mousePos.y, player);
    item.count--;
    renderHotbar();
    return;
  }

  if (item.id === 'ender_pearl') {
    if (item.count <= 0) return;
    item.count--;
    // Teleport with delay
    const tx = mousePos.x, ty = mousePos.y;
    spawnParticles(player.x, player.y, '#4aff6a', 10);
    projectiles.push({x:player.x,y:player.y,vx:(tx-player.x)/20,vy:(ty-player.y)/20,type:'pearl',owner:player,target:{x:tx,y:ty},life:25,isPearl:true});
    renderHotbar();
    return;
  }

  if (item.id === 'fireball') {
    if (item.count <= 0) return;
    item.count--;
    fireProjectile(player, mousePos.x, mousePos.y, item);
    renderHotbar();
    return;
  }

  if (item.id === 'fishing_rod') {
    if (!player.cooldowns.rod) {
      fireProjectile(player, mousePos.x, mousePos.y, item);
      player.cooldowns.rod = 40;
    }
    return;
  }

  if (item.id === 'lava_bucket') {
    lavaZones.push({x:mousePos.x, y:mousePos.y, life:300, maxLife:300});
    item.id = 'empty_bucket';
    item.name = 'Empty Bucket';
    item.icon = '🪣';
    renderHotbar();
    return;
  }

  if (item.id === 'pot_heal') {
    if (item.count <= 0) return;
    item.count--;
    player.hp = Math.min(player.maxHp, player.hp+8);
    spawnParticles(player.x, player.y, '#ff4aaa', 8);
    killFeed('Healed +8 HP', '#ff4aaa');
    renderHotbar();
    return;
  }
  if (item.id === 'pot_strength') {
    if (item.count <= 0) return;
    item.count--;
    player.statusEffects.str = {dur: 15*60, val:3};
    killFeed('Strength II active!', '#ff9900');
    renderHotbar();
    return;
  }
  if (item.id === 'pot_speed') {
    if (item.count <= 0) return;
    item.count--;
    player.statusEffects.spd = {dur: 12*60};
    killFeed('Speed II active!', '#4a9eff');
    renderHotbar();
    return;
  }
  if (item.id === 'pot_invis') {
    if (item.count <= 0) return;
    item.count--;
    player.statusEffects.invis = {dur: 8*60};
    killFeed('Invisible!', '#aaa');
    renderHotbar();
    return;
  }
  if (item.id === 'crossbow') {
    fireProjectile(player, mousePos.x, mousePos.y, item);
    player.cooldowns.crossbow = 50;
    return;
  }

  // Melee attack
  if (item.cat === 'sword' || item.cat === 'axe' || item.cat === 'mace') {
    const rate = getAttackRate(player);
    if (player.cooldowns.melee) return;
    player.cooldowns.melee = rate;
    player.attackSwing = 1.5;

    // Check all bots in range
    let hit = false;
    bots.forEach(bot => {
      if (bot.hp <= 0) return;
      const d = dist(player.x, player.y, bot.x, bot.y);
      const range = getWeaponRange(item);
      if (d < range) {
        hit = true;
        const dmg = calculateDamage(item, player, bot, 0);
        const blocked = bot.blocking && !item.special?.includes('shield_break');
        if (blocked) {
          const bd = dmg * 0.2;
          applyDamage(bot, bd, player, item.cat);
          spawnParticles(bot.x, bot.y, '#4a9eff', 6);
          spawnDmgNum(bot.x, bot.y, 0, '#4a9eff');
          // Break shield on axe
          if (item.special === 'shield_break') {
            const sh = bot.items.find(i=>i.id==='shield');
            if (sh) sh.broken = true;
            killFeed(`${bot.name}'s shield broken!`, '#ff8c00');
          }
        } else {
          applyDamage(bot, dmg, player, item.cat);
          spawnParticles(bot.x, bot.y, '#ff4040', 6);
          spawnDmgNum(bot.x, bot.y, dmg);
          totalDamageDealt += dmg;
          comboCount++;
          comboTimer = 120;
          // Knockback
          const kbForce = item.cat==='axe' ? 6 : 4;
          bot.x += (bot.x-player.x)/d*kbForce;
          bot.y += (bot.y-player.y)/d*kbForce;
        }
      }
    });
    if (!hit) {
      spawnParticles(player.x+(player.facingRight?30:-30), player.y-20, '#555', 3, 1);
    }
  }
}

function handleRightClick() {
  // Right click: explode nearest crystal, or use shield
  const nearCrystal = crystals.find(c => dist(mousePos.x, mousePos.y, c.x, c.y) < 40);
  if (nearCrystal && nearCrystal.owner === player) {
    explodeCrystal(nearCrystal);
    return;
  }
  // Right click on enemy crystal to also explode (crystal pvp)
  if (nearCrystal) {
    explodeCrystal(nearCrystal);
  }
}

function releaseBow() {
  if (!player.isBowCharging) return;
  player.isBowCharging = false;
  const bow = player.items.find(i=>i.cat==='ranged'&&(i.id==='bow'||i.id==='trident'));
  if (!bow || bow.count <= 0) { player.bowCharge=0; return; }
  const chargeRatio = player.bowCharge/60;
  if (chargeRatio < 0.1) { player.bowCharge=0; return; }
  if (bow.id !== 'trident') bow.count--;
  fireProjectile(player, mousePos.x, mousePos.y, bow, chargeRatio);
  player.bowCharge = 0;
  renderHotbar();
}

// ---- FIRE PROJECTILE ----
function fireProjectile(owner, tx, ty, item, charge=1) {
  const dx = tx - owner.x, dy = ty - owner.y;
  const d = Math.sqrt(dx*dx+dy*dy)||1;
  let speed = 14 * charge;
  const types = {bow:'arrow',crossbow:'arrow',trident:'trident',fireball:'fireball',fishing_rod:'fishHook'};
  const type = types[item.id] || 'arrow';
  projectiles.push({
    x: owner.x, y: owner.y-10,
    vx: (dx/d)*speed, vy: (dy/d)*speed,
    type,
    owner,
    damage: item.dmg * charge * (owner.statusEffects?.str ? 1+(owner.statusEffects.str.val/10) : 1),
    life: 80,
    item,
    returned: false,
  });
}

// ---- UPDATE PROJECTILES ----
function updateProjectiles() {
  projectiles = projectiles.filter(p => p.life > 0);
  projectiles.forEach(p => {
    p.x += p.vx;
    p.y += p.vy;
    if (p.type !== 'fishHook') p.vy += 0.18; // gravity
    p.life--;

    // Pearl teleport
    if (p.isPearl) {
      if (p.life < 5) {
        player.x = p.x;
        player.y = p.y;
        spawnParticles(p.x, p.y, '#4aff6a', 12);
        p.life = 0;
      }
      return;
    }

    // Trident return
    if (p.type === 'trident' && p.life < 20) {
      const dx = p.owner.x - p.x, dy = p.owner.y - p.y;
      const d = Math.sqrt(dx*dx+dy*dy)||1;
      p.vx = (dx/d)*12;
      p.vy = (dy/d)*12;
    }

    // Fish hook pull
    if (p.type === 'fishHook' && p.life < 50) {
      const target = p.owner === player ? bots[0] : player;
      if (target && target.hp > 0) {
        const dx = p.x - target.x, dy = p.y - target.y;
        const d = Math.sqrt(dx*dx+dy*dy)||1;
        if (d < 20) {
          // Pull target toward owner
          const ox = p.owner.x-target.x, oy = p.owner.y-target.y;
          const od = Math.sqrt(ox*ox+oy*oy)||1;
          target.x += (ox/od)*4;
          target.y += (oy/od)*4;
          p.life = 0;
          killFeed(p.owner===player?'Hooked!':p.owner.name+' hooked you!','#ff9900');
        }
      }
    }

    // Hit detection
    const targets = p.owner === player ? bots : [player];
    targets.forEach(t => {
      if (t.hp <= 0) return;
      const d = dist(p.x, p.y, t.x, t.y);
      if (d < 22) {
        let dmg = p.damage;
        if (t.blocking) dmg *= 0.2;
        applyDamage(t, dmg, p.owner, p.type);
        if (p.owner === player) { totalDamageDealt += dmg; comboCount++; comboTimer=90; }
        spawnParticles(t.x, t.y, p.type==='fireball'?'#ff6600':'#ffcc00', 6);
        spawnDmgNum(t.x, t.y, dmg);
        if (p.type === 'fireball' && !t.statusEffects) t.statusEffects = {};
        if (p.type === 'fireball') t.statusEffects.fire = {dur:60, tick:0};
        p.life = 0;
      }
    });

    // Bounds
    if (p.x<0||p.x>W||p.y>H+50) p.life=0;
  });
}

// ---- CRYSTALS ----
function placeCrystal(x, y, owner) {
  crystals.push({
    x, y: Math.min(y, H/2+120),
    hp: 10, maxHp: 10,
    owner,
    phase: Math.random()*Math.PI*2,
  });
}

function explodeCrystal(c) {
  const idx = crystals.indexOf(c);
  if (idx !== -1) crystals.splice(idx, 1);
  spawnParticles(c.x, c.y, '#b44aff', 20, 6);
  spawnParticles(c.x, c.y, '#ffffff', 10, 4);

  // AOE damage
  const all = [player, ...bots];
  all.forEach(e => {
    if (e.hp <= 0) return;
    const d = dist(e.x, e.y, c.x, c.y);
    if (d < 100) {
      const dmg = (1 - d/100) * 18;
      if (e === player && c.owner === player) return; // don't self-explode (basic safety)
      applyDamage(e, dmg, c.owner, 'crystal');
      spawnDmgNum(e.x, e.y, dmg, '#b44aff');
    }
  });

  // Chain react nearby crystals
  crystals.filter(other => dist(other.x,other.y,c.x,c.y) < 60).forEach(other => {
    setTimeout(() => explodeCrystal(other), 200);
  });
}

// ---- DAMAGE ----
function calculateDamage(item, attacker, target, fallHeight=0) {
  let dmg = item.dmg || 0;
  // Strength
  if (attacker.statusEffects?.str) dmg += attacker.statusEffects.str.val;
  // 1.8: no sweep, just base dmg
  // Mace fall bonus
  if (item.id === 'mace') dmg += fallHeight * 2;
  // Critical (1.21 axe)
  if (item.cat === 'axe' && Math.random() < 0.15) dmg *= 1.4;
  // Netherite KB resist
  if (target?.id === 'sword_netherite' || target?.statusEffects?.kb_resist) dmg *= 0.92;
  return parseFloat(dmg.toFixed(1));
}

function applyDamage(target, dmg, source, type) {
  if (target.invincibleTimer > 0) return;
  if (target.hp <= 0) return;

  target.hp -= dmg;
  target.invincibleTimer = 8;

  if (target.hp <= 0) {
    // Totem check
    if (target.totemActive) {
      target.hp = 4;
      target.totemActive = false;
      target.statusEffects.str = {dur:120, val:2};
      killFeed((target === player ? 'You' : target.name) + ' popped totem!', '#ffd700');
      spawnParticles(target.x, target.y, '#ffd700', 20, 5);
      return;
    }
    // Death
    if (target === player) return; // handled in gameTick
    // Bot died
    target.hp = 0;
    playerKills++;
    killFeed(`☠ ${target.name} eliminated!`, '#e8414b');
    spawnParticles(target.x, target.y, '#ff4040', 30, 5);
    // Respawn after delay (for multi-bot mode)
    if (gameState.botCount > 1) {
      setTimeout(() => {
        if (!gameActive) return;
        target.hp = target.maxHp;
        target.x = W/2 + (Math.random()-0.5)*300;
        target.y = H/2 - 100;
        target.invincibleTimer = 60;
      }, 3000);
    }
  }
}

function handlePlayerDeath() {
  playerDeaths++;
  if (bots.every(b => b.hp <= 0)) { handleVictory(); return; }
  if (gameState.botCount === 1) { handleDefeat(); return; }
  // Respawn
  player.hp = player.maxHp;
  player.x = W/2;
  player.y = H/2 - 50;
  player.invincibleTimer = 120;
  killFeed('You were eliminated! Respawning...', '#888');
  gameLoop = requestAnimationFrame(gameTick);
}

// ---- STATUS EFFECTS ----
function tickStatusEffects(ent) {
  Object.keys(ent.statusEffects).forEach(k => {
    const se = ent.statusEffects[k];
    se.dur--;
    if (k === 'fire') {
      se.tick = (se.tick||0)+1;
      if (se.tick % 20 === 0) {
        ent.hp -= 1;
        if (ent === player) spawnDmgNum(player.x, player.y, 1, '#ff6600');
      }
    }
    if (se.dur <= 0) delete ent.statusEffects[k];
  });
}

// ---- HELPERS ----
function dist(x1,y1,x2,y2) { return Math.sqrt((x2-x1)**2+(y2-y1)**2); }
function getAttackRate(ent) {
  const item = ent.items[ent.hotbar];
  if (!item) return 10;
  if (gameState.pvpMode === '1.8') return Math.floor(10 / (item.aspd||0.7));
  return Math.floor(8 / (item.aspd||0.7));
}
function getWeaponRange(item) {
  if (!item) return 60;
  if (item.cat === 'axe') return 65;
  if (item.cat === 'mace') return 70;
  return 60;
}

// ---- UI ----
function updateHealthUI() {
  if (!player) return;
  const hpPct = Math.max(0, player.hp/player.maxHp)*100;
  document.getElementById('p-hp-bar').style.width = hpPct+'%';
  document.getElementById('p-hp-bar').style.background = hpPct>50?'linear-gradient(90deg,#e84040,#ff6060)':hpPct>25?'linear-gradient(90deg,#ff9900,#ffcc00)':'linear-gradient(90deg,#ff2020,#ff5050)';
  document.getElementById('p-hp-text').textContent = `${Math.max(0,Math.ceil(player.hp))}/${player.maxHp}`;
}

function updateStatusEffects() {
  const el = document.getElementById('status-effects');
  el.innerHTML = '';
  const se = player.statusEffects;
  const badges = {
    str: {label:'⚡ STR', color:'#ff9900', border:'#ff6600'},
    spd: {label:'💨 SPD', color:'#4a9eff', border:'#2277cc'},
    invis:{label:'👻 INVIS',color:'#aaa',border:'#666'},
    fire: {label:'🔥 BURN',color:'#ff4400',border:'#cc2200'},
  };
  Object.keys(se).forEach(k => {
    if (!badges[k]) return;
    const b = badges[k];
    const div = document.createElement('div');
    div.className = 'se-badge';
    div.style.cssText = `color:${b.color};border-color:${b.border};background:rgba(0,0,0,0.6);`;
    const secs = Math.ceil(se[k].dur/60);
    div.textContent = `${b.label} ${secs}s`;
    el.appendChild(div);
  });
  if (player.totemActive) {
    const div = document.createElement('div');
    div.className = 'se-badge';
    div.style.cssText = 'color:#ffd700;border-color:#cc9900;background:rgba(0,0,0,0.6);';
    div.textContent = '🗿 TOTEM';
    el.appendChild(div);
  }
}

function updateCombo() {
  if (comboTimer > 0) {
    comboTimer--;
    const el = document.getElementById('combo-display');
    el.style.display = 'block';
    if (comboCount > 2) {
      el.innerHTML = `<div class="combo-num" style="font-size:${2+comboCount*0.2}rem">${comboCount}x</div><div class="combo-label">COMBO</div>`;
    }
  } else {
    comboCount = 0;
    document.getElementById('combo-display').style.display = 'none';
  }
}

function renderHotbar() {
  if (!player) return;
  const hb = document.getElementById('hotbar');
  hb.innerHTML = '';
  player.items.forEach((item, i) => {
    const div = document.createElement('div');
    div.className = `hslot ${i === player.hotbar ? 'active' : ''}`;
    const cd = player.cooldowns.melee && i === player.hotbar ? player.cooldowns.melee : 0;
    const countStr = item.count > 1 ? `<div style="position:absolute;bottom:2px;right:3px;font-size:9px;color:#ffd700;font-weight:700;">${item.count}</div>` : '';
    const cdOverlay = cd > 0 ? `<div class="hcooldown">${(cd/20).toFixed(1)}</div>` : '';
    const bow = item.id==='bow'&&player.isBowCharging ? `<div class="hcooldown" style="background:rgba(255,140,0,0.7);">${Math.floor(player.bowCharge/60*100)}%</div>` : '';
    div.innerHTML = `<div class="hkey">${i+1}</div><div class="hicon">${item.icon}</div><div class="hname">${item.name}</div>${countStr}${cdOverlay}${bow}`;
    div.onclick = () => { player.hotbar = i; renderHotbar(); };
    hb.appendChild(div);
  });
}

function killFeed(msg, color='#e8e0d0') {
  const el = document.getElementById('killfeed');
  const entry = document.createElement('div');
  entry.className = 'kf-entry';
  entry.style.borderColor = color;
  entry.style.color = color;
  entry.textContent = msg;
  el.appendChild(entry);
  if (el.children.length > 6) el.removeChild(el.firstChild);
  setTimeout(() => entry.remove(), 3000);
}

// ---- RESULTS ----
function handleVictory() {
  gameActive = false;
  showResults(true);
}
function handleDefeat() {
  gameActive = false;
  showResults(false);
}
function endGame() {
  gameActive = false;
  if (gameLoop) cancelAnimationFrame(gameLoop);
  showScreen('menu-screen');
}

function showResults(win) {
  if (gameLoop) cancelAnimationFrame(gameLoop);
  const elapsed = Math.floor((Date.now()-startTime)/1000);
  const mins = Math.floor(elapsed/60), secs = elapsed%60;
  document.getElementById('result-title').textContent = win ? '⚔ VICTORY' : '☠ DEFEATED';
  document.getElementById('result-title').className = 'result-title ' + (win?'win':'loss');
  document.getElementById('result-sub').textContent = win ? `You dismantled ${gameState.difficulty.toUpperCase()} bots in ${mins}:${String(secs).padStart(2,'0')}` : `The bots got you in ${mins}:${String(secs).padStart(2,'0')}`;
  document.getElementById('result-stats').innerHTML = `
    <div class="stat-item"><div class="stat-val">${playerKills}</div><div class="stat-label">Kills</div></div>
    <div class="stat-item"><div class="stat-val">${playerDeaths}</div><div class="stat-label">Deaths</div></div>
    <div class="stat-item"><div class="stat-val">${totalDamageDealt.toFixed(0)}</div><div class="stat-label">Damage Dealt</div></div>
    <div class="stat-item"><div class="stat-val">${comboCount > 0 ? comboCount : '—'}</div><div class="stat-label">Max Combo</div></div>
  `;
  showScreen('result-screen');
}

// ---- ARENA INIT ----
const origInitGame = initGame;
function initGame() {
  buildArena();
  origInitGame();
  killFeed(`Kit: ${gameState.kitName} | ${getModeLabel()}`, '#4a9eff');
  killFeed('WASD: Move | Click: Attack | Shift: Block | 1-9: Items', '#888');
}
// Override
window.initGame = initGame;
</script>
