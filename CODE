<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quartisim's PVP</title>
<link href="https://fonts.googleapis.com/css2?family=VT323&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0a0f;
  --panel: #111118;
  --border: #2a2a3a;
  --accent: #e8414b;
  --accent2: #ff8c00;
  --blue: #4a9eff;
  --green: #4aff6a;
  --purple: #b44aff;
  --cyan: #00e5ff;
  --text: #e8e0d0;
  --muted: #556;
  --gold: #ffd700;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Rajdhani',sans-serif;min-height:100vh;overflow:hidden;}
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,0.04) 3px,rgba(0,0,0,0.04) 4px);pointer-events:none;z-index:9999;}

.screen{display:none;position:fixed;inset:0;overflow-y:auto;}
.screen.active{display:flex;flex-direction:column;align-items:center;justify-content:center;}

#menu-screen{background:radial-gradient(ellipse at 50% 30%,#1a0808 0%,#0a0a0f 70%);}
.menu-bg-particles{position:fixed;inset:0;pointer-events:none;z-index:0;}
.particle-orb{position:absolute;border-radius:50%;animation:floatOrb linear infinite;}
@keyframes floatOrb{0%{transform:translateY(100vh) scale(0);opacity:0;}10%{opacity:1;}90%{opacity:0.5;}100%{transform:translateY(-100px) scale(1.5);opacity:0;}}
.menu-content{position:relative;z-index:1;text-align:center;padding:20px;}
.game-title{font-family:'VT323',monospace;font-size:clamp(3rem,8vw,6rem);color:var(--accent);text-shadow:0 0 30px rgba(232,65,75,0.8),0 0 80px rgba(232,65,75,0.3);letter-spacing:0.05em;line-height:1;}
.game-subtitle{font-size:1rem;letter-spacing:0.5em;color:var(--muted);margin-top:-8px;margin-bottom:40px;text-transform:uppercase;}
.menu-btn{display:block;width:280px;padding:14px 30px;margin:10px auto;background:transparent;border:2px solid var(--accent);color:var(--accent);font-family:'Rajdhani',sans-serif;font-size:1.2rem;cursor:pointer;position:relative;letter-spacing:0.1em;text-transform:uppercase;overflow:hidden;}
.menu-btn::before{content:'';position:absolute;inset:0;background:var(--accent);transform:scaleX(0);transition:transform 0.2s;transform-origin:left;}
.menu-btn:hover{color:#000;}
.menu-btn:hover::before{transform:scaleX(1);}
.menu-btn span{position:relative;z-index:1;}
.menu-btn.blue{border-color:var(--blue);color:var(--blue);}
.menu-btn.blue::before{background:var(--blue);}
.version-tag{font-size:0.75rem;color:var(--muted);margin-top:30px;letter-spacing:0.3em;}

#kit-screen{background:var(--bg);padding:20px;}
.kit-layout{display:grid;grid-template-columns:1fr 1fr;gap:20px;width:100%;max-width:1100px;margin:0 auto;}
.kit-panel{background:var(--panel);border:1px solid var(--border);padding:20px;}
.panel-title{font-family:'VT323',monospace;font-size:1.8rem;color:var(--accent);}
.items-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;}
.item-card{background:#0d0d15;border:1px solid var(--border);padding:10px;cursor:pointer;transition:all 0.15s;text-align:center;}
.item-card:hover{border-color:var(--accent);}
.item-icon{font-size:1.8rem;}
.item-name{font-size:0.65rem;font-weight:700;text-transform:uppercase;}

#game-screen{background:var(--bg);padding:0;}
#gameCanvas{display:block;width:100%;height:100%;cursor:crosshair;}
#game-hud{position:fixed;inset:0;pointer-events:none;z-index:100;}

.hud-health-area{position:absolute;bottom:80px;left:50%;transform:translateX(-50%);}
.health-bar-wrap{width:300px;}
.hbar{height:14px;background:#111;border:1px solid #333;border-radius:2px;overflow:hidden;}
.hbar-fill{height:100%;background:linear-gradient(90deg,#e84040,#ff6060);}

.hotbar{position:absolute;bottom:16px;left:50%;transform:translateX(-50%);display:flex;gap:4px;background:rgba(0,0,0,0.7);border:1px solid #333;padding:5px;}
.hslot{width:56px;height:56px;background:#0a0a12;border:2px solid #333;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.hslot.active{border-color:var(--accent);}
.hicon{font-size:1.5rem;}

.killfeed{position:absolute;top:16px;right:16px;}
.mode-badge{position:absolute;top:16px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.8);border:1px solid var(--accent);padding:4px 20px;font-size:0.75rem;}

#crosshair{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:20px;height:20px;pointer-events:none;}
#crosshair::before,#crosshair::after{content:'';position:absolute;background:rgba(255,255,255,0.8);}
#crosshair::before{width:2px;height:100%;left:50%;transform:translateX(-50%);}
#crosshair::after{height:2px;width:100%;top:50%;transform:translateY(-50%);}

.ping-badge{position:absolute;bottom:80px;right:16px;font-size:0.65rem;color:#4aff6a;}

.back-btn{background:transparent;border:1px solid #333;color:#666;padding:8px 20px;cursor:pointer;font-family:'Rajdhani',sans-serif;}
.start-fight-btn{width:100%;padding:16px;background:var(--accent);border:none;color:#000;cursor:pointer;font-family:'Rajdhani',sans-serif;}

#player-hand{position:fixed;font-size:2rem;pointer-events:none;z-index:200;user-select:none;}
</style>
</head>
<body>

<div class="tooltip" id="tooltip" style="display:none;position:fixed;background:#0d0d18;border:1px solid var(--accent);padding:8px;z-index:9000;max-width:200px;">
  <div id="tt-name"></div>
</div>

<div class="screen active" id="menu-screen">
  <div class="menu-bg-particles" id="bg-particles"></div>
  <div class="menu-content">
    <div class="game-title">QUARTISIM'S</div>
    <div class="game-title" style="font-size:clamp(2rem,6vw,4.5rem);color:#fff;">PVP</div>
    <div class="game-subtitle">No rules. Just combat.</div>
    <button class="menu-btn" onclick="showScreen('kit-screen')"><span>⚔ Build Kit & Fight</span></button>
    <button class="menu-btn blue" onclick="quickFight()"><span>⚡ Quick Fight</span></button>
    <div class="version-tag">v1.0 — 1.8 PVP</div>
  </div>
</div>

<div class="screen" id="kit-screen">
  <div style="width:100%;max-width:1100px;margin:0 auto;padding:20px;">
    <button class="back-btn" onclick="showScreen('menu-screen')">← Back</button>
    <h2 style="font-family:'VT323',monospace;font-size:2rem;color:var(--accent);">KIT BUILDER</h2>
  </div>
  <div class="kit-layout">
    <div>
      <div class="kit-panel">
        <div class="panel-title">🗡 Items</div>
        <div class="items-grid" id="items-grid"></div>
      </div>
    </div>
    <div>
      <div class="kit-panel">
        <div class="panel-title">🎒 Your Kit</div>
        <div id="kit-slots"></div>
      </div>
      <button class="start-fight-btn" onclick="startFight()">START FIGHT</button>
    </div>
  </div>
</div>

<div class="screen" id="game-screen">
  <canvas id="gameCanvas"></canvas>
  <div id="player-hand">👊</div>
  <div id="game-hud">
    <div id="crosshair"></div>
    <div class="mode-badge">1.8 PVP</div>
    <div class="killfeed" id="killfeed"></div>
    <div class="hud-health-area">
      <div class="health-bar-wrap">
        <div class="hbar"><div class="hbar-fill" id="p-hp-bar" style="width:100%"></div></div>
        <div style="font-size:0.7rem;color:#aaa;text-align:right;"><span id="p-hp-text">20/20</span></div>
      </div>
    </div>
    <div class="hotbar" id="hotbar"></div>
    <div class="ping-badge">⬀ 4ms</div>
    <button style="position:absolute;top:16px;left:16px;" class="back-btn" onclick="endGame()">✕ Quit</button>
  </div>
</div>

<script>
// ============================================================
//  QUARTISIM'S PVP — Working Version
// ============================================================

const ITEMS = [
  {id:'sword_dia',   name:'Diamond Sword',icon:'💎', dmg:7, aspd:0.75},
  {id:'bow',         name:'Bow',          icon:'🏹', dmg:9, aspd:0.3},
  {id:'pot_heal',    name:'Healing Pot',  icon:'🧪', dmg:0, aspd:0},
  {id:'shield',      name:'Shield',       icon:'🛡', dmg:0, aspd:0},
  {id:'ender_pearl', name:'Ender Pearl',  icon:'🟢', dmg:0, aspd:0},
  {id:'crystal',     name:'End Crystal',  icon:'🔮', dmg:0, aspd:0},
  {id:'totem',       name:'Totem',        icon:'🗿', dmg:0, aspd:0},
  {id:'mace',        name:'Mace',         icon:'🏛', dmg:6, aspd:0.5},
];

let gameState = { pvpMode: '1.8', difficulty: 'medium', botCount: 1, arena: 'flat', playerKit: [] };
let kitSlots = Array(9).fill(null);
let player = null;
let bots = [];
let gameActive = false;

const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');
let W, H;

// ---- SCREENS ----
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  if (id === 'kit-screen') renderItemGrid();
}

// ---- QUICK FIGHT ----
function quickFight() {
  kitSlots = [
    {...ITEMS.find(i=>i.id==='sword_dia')},
    {...ITEMS.find(i=>i.id==='pot_heal')},
    {...ITEMS.find(i=>i.id==='bow')},
    {...ITEMS.find(i=>i.id==='shield')},
    {...ITEMS.find(i=>i.id==='ender_pearl')},
    null,null,null,null
  ];
  gameState.playerKit = kitSlots.filter(s => s);
  showScreen('game-screen');
  setTimeout(() => initGame(), 50);
}

// ---- START FIGHT ----
function startFight() {
  const filled = kitSlots.filter(s => s);
  if (filled.length === 0) return alert('Add items!');
  gameState.playerKit = filled;
  showScreen('game-screen');
  setTimeout(() => initGame(), 50);
}

// ---- KIT BUILDER UI ----
function renderItemGrid() {
  const grid = document.getElementById('items-grid');
  grid.innerHTML = '';
  ITEMS.forEach(item => {
    const div = document.createElement('div');
    div.className = 'item-card';
    div.innerHTML = `<div class="item-icon">${item.icon}</div><div class="item-name">${item.name}</div>`;
    div.onclick = () => {
      const idx = kitSlots.findIndex(s => !s);
      if (idx !== -1) kitSlots[idx] = {...item};
      renderKitSlots();
    };
    grid.appendChild(div);
  });
  renderKitSlots();
}

function renderKitSlots() {
  const container = document.getElementById('kit-slots');
  container.innerHTML = '';
  kitSlots.forEach((item, i) => {
    const slot = document.createElement('div');
    slot.style.cssText = 'display:inline-block;width:60px;height:60px;background:#0a0a12;border:1px solid #333;margin:5px;text-align:center;line-height:30px;cursor:pointer;font-size:1.5rem;';
    if (item) {
      slot.innerHTML = item.icon;
      slot.onclick = () => { kitSlots[i] = null; renderKitSlots(); };
    } else {
      slot.innerHTML = '+';
      slot.style.color = '#333';
    }
    container.appendChild(slot);
  });
}

// ---- GAME ENGINE ----
function initGame() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
  gameActive = true;

  // Initialize player
  player = {
    x: W/2, y: H/2,
    hp: 20, maxHp: 20,
    items: gameState.playerKit,
    hotbar: 0,
    facingRight: true,
    blocking: false,
    isBowCharging: false,
    vx: 0, vy: 0,
  };

  bots = [
    { x: W/2 + 200, y: H/2, hp: 20, maxHp: 20, name: 'Bot1', facingRight: false },
    { x: W/2 - 200, y: H/2, hp: 20, maxHp: 20, name: 'Bot2', facingRight: true },
  ];

  renderHotbar();
  updateHealthUI();
  gameLoop();
}

function gameLoop() {
  if (!gameActive) return;

  // Draw
  ctx.fillStyle = '#87CEEB';
  ctx.fillRect(0, 0, W, H);

  // Ground
  ctx.fillStyle = '#5a8a3c';
  ctx.fillRect(0, H/2 + 100, W, H);

  // Player
  if (player) {
    ctx.fillStyle = '#3a6aaa';
    ctx.fillRect(player.x - 10, player.y - 20, 20, 30);
    ctx.fillStyle = '#f5c080';
    ctx.fillRect(player.x - 9, player.y - 40, 18, 18);

    const item = player.items[player.hotbar];
    if (item) {
      ctx.font = '1.5rem serif';
      ctx.fillText(item.icon, player.x + 10, player.y - 15);
    }
  }

  // Bots
  bots.forEach(bot => {
    ctx.fillStyle = '#c94444';
    ctx.fillRect(bot.x - 10, bot.y - 20, 20, 30);
    ctx.fillStyle = '#f5c080';
    ctx.fillRect(bot.x - 9, bot.y - 40, 18, 18);

    ctx.fillStyle = '#fff';
    ctx.font = '10px sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(bot.name, bot.x, bot.y - 55);
  });

  updateHealthUI();
  requestAnimationFrame(gameLoop);
}

function renderHotbar() {
  const hb = document.getElementById('hotbar');
  hb.innerHTML = '';
  if (!player) return;
  player.items.forEach((item, idx) => {
    const slot = document.createElement('div');
    slot.className = `hslot ${idx === player.hotbar ? 'active' : ''}`;
    slot.innerHTML = `<div class="hicon">${item.icon}</div>`;
    slot.onclick = () => { player.hotbar = idx; renderHotbar(); };
    hb.appendChild(slot);
  });
}

function updateHealthUI() {
  if (!player) return;
  const pct = (player.hp / player.maxHp) * 100;
  document.getElementById('p-hp-bar').style.width = pct + '%';
  document.getElementById('p-hp-text').textContent = player.hp + '/' + player.maxHp;
}

// ---- INPUT ----
document.addEventListener('keydown', e => {
  if (!gameActive || !player) return;
  if (e.code === 'ArrowLeft' || e.key === 'a') player.x -= 10;
  if (e.code === 'ArrowRight' || e.key === 'd') player.x += 10;
  if (e.code === 'ArrowUp' || e.key === 'w') player.y -= 10;
  if (e.code === 'ArrowDown' || e.key === 's') player.y += 10;
  for (let i = 0; i < 9; i++) {
    if (e.code === `Digit${i+1}`) player.hotbar = Math.min(i, player.items.length - 1);
  }
});

canvas.addEventListener('mousemove', (e) => {
  const hand = document.getElementById('player-hand');
  hand.style.left = e.clientX + 'px';
  hand.style.top = e.clientY + 'px';
});

canvas.addEventListener('click', (e) => {
  if (!gameActive || !player) return;
  const dx = e.clientX - player.x;
  const dy = e.clientY - player.y;
  const botHit = bots.find(bot => Math.hypot(dx - (bot.x - player.x), dy - (bot.y - player.y)) < 40);
  if (botHit) {
    botHit.hp -= 3;
    if (botHit.hp <= 0) botHit.hp = 20;
  }
});

function endGame() {
  gameActive = false;
  showScreen('menu-screen');
}

// Init
renderItemGrid();
</script>
</body>
</html>