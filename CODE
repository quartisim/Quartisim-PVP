// ---- ARENA GEOMETRY ----
let arenaObstacles = [];
let arenaEdge = 400;

function buildArena() {
  arenaObstacles = [];
  const type = gameState.arena;
  if (type === 'pillars') {
    const positions = [[-150,-120],[150,-120],[-150,120],[150,120],[0,-200],[0,200],[-250,0],[250,0]];
    positions.forEach(([px,py]) => {
      arenaObstacles.push({x:W/2+px-16,y:H/2+py-40,w:32,h:80,color:'#7a7a7a',top:'#9a9a9a'});
    });
  } else if (type === 'sky') {
    const plats = [[-200,20,120,16],[200,-30,100,16],[0,-100,140,16],[-280,60,80,16],[280,0,80,16],[0,80,200,16]];
    plats.forEach(([px,py,pw,ph]) => {
      arenaObstacles.push({x:W/2+px-pw/2,y:H/2+py,w:pw,h:ph,color:'#5a8a3c',top:'#4a7a2c'});
    });
    arenaEdge = 500;
  }
}

// ---- DRAW ARENA ----
function drawArena() {
  const skyGrad = ctx.createLinearGradient(0,0,0,H);
  if (gameState.arena === 'sky') {
    skyGrad.addColorStop(0,'#1a3a6a');
    skyGrad.addColorStop(1,'#0a1a3a');
  } else {
    skyGrad.addColorStop(0,'#87CEEB');
    skyGrad.addColorStop(1,'#c8e8ff');
  }
  ctx.fillStyle = skyGrad;
  ctx.fillRect(0,0,W,H);

  if (gameState.arena !== 'sky') {
    ctx.fillStyle = '#5a8a3c';
    ctx.fillRect(0, H/2+160, W, H);
    ctx.fillStyle = '#4a7a2c';
    ctx.fillRect(0, H/2+155, W, 10);
    ctx.strokeStyle = 'rgba(0,0,0,0.05)';
    ctx.lineWidth = 1;
    for (let x = 0; x < W; x += 32) {
      ctx.beginPath(); ctx.moveTo(x, H/2+160); ctx.lineTo(x, H); ctx.stroke();
    }
    ctx.strokeStyle = 'rgba(232,65,75,0.3)';
    ctx.lineWidth = 2;
    ctx.setLineDash([8,8]);
    ctx.strokeRect(W/2-arenaEdge, H/2-280, arenaEdge*2, 440);
    ctx.setLineDash([]);
  }

  arenaObstacles.forEach(ob => {
    ctx.fillStyle = ob.color;
    ctx.fillRect(ob.x, ob.y, ob.w, ob.h);
    if (ob.top) {
      ctx.fillStyle = ob.top;
      ctx.fillRect(ob.x, ob.y, ob.w, 6);
    }
    ctx.fillStyle = 'rgba(0,0,0,0.15)';
    ctx.fillRect(ob.x+4, ob.y+ob.h, ob.w-4, 8);
  });
}

// ---- DRAW ENTITY ----
function drawPlayer(ent, isPlayer=false) {
  const {x, y} = ent;
  const alpha = (ent.statusEffects.invis && !isPlayer) ? 0.15 : 1;
  ctx.globalAlpha = alpha;

  ctx.fillStyle = 'rgba(0,0,0,0.25)';
  ctx.beginPath();
  ctx.ellipse(x, y+2, 14, 5, 0, 0, Math.PI*2);
  ctx.fill();

  const bodyColor = isPlayer ? '#3a6aaa' : ent.color;
  ctx.fillStyle = ent.invincibleTimer > 0 ? 'rgba(255,100,100,0.8)' : bodyColor;
  ctx.fillRect(x-10, y-28, 20, 26);

  ctx.fillStyle = '#f5c080';
  ctx.fillRect(x-9, y-46, 18, 18);

  ctx.fillStyle = '#222';
  const eyeDir = ent.facingRight ? 1 : -1;
  ctx.fillRect(x+(eyeDir*2)-1, y-41, 3, 3);

  if (isPlayer) {
    ctx.fillStyle = 'rgba(100,150,255,0.35)';
    ctx.fillRect(x-10, y-28, 20, 26);
  } else {
    ctx.fillStyle = 'rgba(200,80,80,0.3)';
    ctx.fillRect(x-10, y-28, 20, 26);
  }

  const curItem = ent.items[ent.hotbar];
  if (curItem && ent.attackSwing > 0) {
    const swingAngle = ent.facingRight ? -ent.attackSwing : Math.PI + ent.attackSwing;
    ctx.save();
    ctx.translate(x + (ent.facingRight ? 10 : -10), y-18);
    ctx.rotate(swingAngle);
    ctx.font = '18px serif';
    ctx.fillStyle = '#fff';
    ctx.fillText(curItem.icon, -6, 6);
    ctx.restore();
  } else if (curItem) {
    ctx.font = '16px serif';
    ctx.fillText(curItem.icon, x + (ent.facingRight ? 12 : -26), y-16);
  }

  if (ent.blocking) {
    ctx.fillStyle = 'rgba(74,158,255,0.6)';
    const sx = ent.facingRight ? x+12 : x-22;
    ctx.fillRect(sx, y-35, 10, 28);
  }

  if (!isPlayer) {
    ctx.globalAlpha = 1;
    ctx.fillStyle = 'rgba(0,0,0,0.6)';
    const nw = ent.name.length * 5.5 + 8;
    ctx.fillRect(x - nw/2, y-62, nw, 14);
    ctx.fillStyle = '#fff';
    ctx.font = '10px "Rajdhani",sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(ent.name, x, y-51);
    ctx.textAlign = 'left';

    const bw = 44;
    ctx.fillStyle = '#111';
    ctx.fillRect(x-bw/2, y-50, bw, 5);
    ctx.fillStyle = ent.hp/ent.maxHp > 0.5 ? '#4aff6a' : ent.hp/ent.maxHp > 0.25 ? '#ff9900' : '#ff4040';
    ctx.fillRect(x-bw/2, y-50, bw*(ent.hp/ent.maxHp), 5);
  }

  if (ent.statusEffects.str) { ctx.font='10px serif'; ctx.fillText('⚡',x-6,y-54); }
  if (ent.statusEffects.fire) { ctx.font='12px serif'; ctx.fillText('🔥',x-6,y-62); }

  ctx.globalAlpha = 1;
}

// ---- DRAW PROJECTILES ----
function drawProjectiles() {
  projectiles.forEach(p => {
    ctx.save();
    ctx.translate(p.x, p.y);
    if (p.type === 'arrow') {
      ctx.rotate(Math.atan2(p.vy, p.vx));
      ctx.fillStyle = '#8B6914';
      ctx.fillRect(-8, -1.5, 16, 3);
      ctx.fillStyle = '#555';
      ctx.fillRect(6, -1.5, 4, 3);
    } else if (p.type === 'fireball') {
      ctx.font = '18px serif';
      ctx.fillText('🔥', -9, 7);
    } else if (p.type === 'trident') {
      ctx.rotate(Math.atan2(p.vy, p.vx));
      ctx.font = '18px serif';
      ctx.fillText('🔱', -9, 7);
    } else if (p.type === 'fishHook') {
      ctx.fillStyle = '#ccc';
      ctx.beginPath();
      ctx.arc(0,0,3,0,Math.PI*2);
      ctx.fill();
      if (p.owner) {
        ctx.strokeStyle = 'rgba(200,200,200,0.4)';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(0,0);
        ctx.lineTo(p.owner.x - p.x, p.owner.y - p.y);
        ctx.stroke();
      }
    } else if (p.type === 'pearl') {
      ctx.fillStyle = '#4aff6a';
      ctx.beginPath();
      ctx.arc(0,0,5,0,Math.PI*2);
      ctx.fill();
    }
    ctx.restore();
  });
}

