let kitSlots = Array(9).fill(null);
let selectedItemId = null;

function renderItemGrid() {
  const grid = document.getElementById('items-grid');
  const cats = ['sword','axe','mace','ranged','crystal','potion','armor','special'];
  grid.innerHTML = '';
  cats.forEach(cat => {
    const catItems = ITEMS.filter(i => i.cat === cat);
    catItems.forEach(item => {
      const inKit = kitSlots.some(s => s && s.id === item.id);
      const div = document.createElement('div');
      div.className = `item-card ${inKit ? 'in-kit' : ''}`;
      div.innerHTML = `
        <span class="item-rarity rarity-${item.rarity.toLowerCase()}">${item.rarity}</span>
        <span class="item-icon">${item.icon}</span>
        <div class="item-name">${item.name}</div>
        <div class="item-stat">${item.cat.toUpperCase()}</div>
      `;
      div.onclick = () => addToKit(item);
      div.onmouseenter = (e) => showTooltip(e, item);
      div.onmouseleave = hideTooltip;
      grid.appendChild(div);
    });
  });
  renderKitSlots();
}

function addToKit(item) {
  if (kitSlots.some(s => s && s.id === item.id)) { removeFromKit(item.id); return; }
  const empty = kitSlots.findIndex(s => !s);
  if (empty === -1) { document.getElementById('kit-warning').textContent = '⚠ Kit full! Remove an item first.'; return; }
  kitSlots[empty] = {...item, count: getDefaultCount(item)};
  document.getElementById('kit-warning').textContent = '';
  renderItemGrid();
}

function removeFromKit(id) {
  const i = kitSlots.findIndex(s => s && s.id === id);
  if (i !== -1) kitSlots[i] = null;
  renderItemGrid();
}

function getDefaultCount(item) {
  if (item.cat === 'crystal') return 10;
  if (item.cat === 'potion') return 3;
  if (item.id === 'bow') return 64; // arrows
  if (item.id === 'fireball') return 3;
  if (item.id === 'ender_pearl') return 4;
  return 1;
}

function renderKitSlots() {
  const container = document.getElementById('kit-slots');
  container.innerHTML = '';
  kitSlots.forEach((item, i) => {
    const div = document.createElement('div');
    div.className = `kit-slot ${item ? 'filled' : ''}`;
    if (item) {
      div.innerHTML = `<span class="slot-icon">${item.icon}</span><span class="slot-name">${item.name}</span><span class="remove-x">✕</span>`;
      div.onclick = () => removeFromKit(item.id);
    } else {
      div.innerHTML = `<span style="font-size:1.2rem;color:#333;">+</span><span class="slot-name">empty</span>`;
    }
    container.appendChild(div);
  });
}

function showTooltip(e, item) {
  const tt = document.getElementById('tooltip');
  document.getElementById('tt-rarity').textContent = ['C','B','A','S'].includes(item.rarity) ? `[${item.rarity}-TIER]` : '';
  document.getElementById('tt-rarity').style.color = {C:'#aaa',B:'var(--accent2)',A:'var(--purple)',S:'var(--cyan)'}[item.rarity];
  document.getElementById('tt-name').textContent = item.name;
  let stats = item.desc;
  if (item.dmg > 0) stats += `\nDMG: ${item.dmg} | SPD: ${Math.round(item.aspd*100)}%`;
  document.getElementById('tt-stats').textContent = stats;
  tt.classList.add('show');
  moveTT(e);
}

function moveTT(e) {
  const tt = document.getElementById('tooltip');
  tt.style.left = (e.clientX + 12) + 'px';
  tt.style.top = (e.clientY - 10) + 'px';
}
document.addEventListener('mousemove', e => { if(document.getElementById('tooltip').classList.contains('show')) moveTT(e); });
function hideTooltip() { document.getElementById('tooltip').classList.remove('show'); }

